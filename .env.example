# Transport mode: "nakama" or "offline"
EXPO_PUBLIC_GAME_TRANSPORT=nakama

# Nakama server for deployed web clients (public HTTPS/WSS endpoint).
# Example: nakama.your-domain.com
EXPO_PUBLIC_NAKAMA_HOST=your-nakama-host.example.com
EXPO_PUBLIC_NAKAMA_PORT=443
EXPO_PUBLIC_NAKAMA_USE_SSL=true
EXPO_PUBLIC_NAKAMA_SOCKET_SERVER_KEY=your-server-key
EXPO_PUBLIC_NAKAMA_TIMEOUT_MS=7000
